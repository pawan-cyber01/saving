rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidAmount() {
      return request.resource.data.amount is number && request.resource.data.amount > 0;
    }

    function isValidString(field) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= 500;
    }

    // ─── Users collection ──────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Profile & settings documents
      match /data/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'name','email','photoURL','defaultDailySaving','currency',
            'notifDailySaving','notifBudgetExceeded','notifGoalCompleted',
            'notifWithdrawal','savedUpiId','savedUpiName','fcmToken',
            'createdAt','updatedAt','monthlyIncome','monthlyBudget',
            'dailyBudget','currentStreak','longestStreak','lastSavedDate',
            'totalLocked','lastWithdrawal','lastUpdated'
          ]);
      }

      // Daily savings (doc ID = YYYY-MM-DD)
      match /savings/{dateId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isValidAmount();
        allow delete: if false; // Savings cannot be deleted
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidAmount()
          && request.resource.data.category is string
          && request.resource.data.date is string;
        allow update: if isOwner(uid) && isValidAmount();
        allow delete: if isOwner(uid);
      }

      // Savings Goals
      match /goals/{goalId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 100
          && request.resource.data.targetAmount is number
          && request.resource.data.targetAmount > 0;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Income
      match /income/{incomeId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── Announcements (admin write, authenticated read) ──────────
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ─── Admin users index (admin only) ───────────────────────────
    match /adminUsers/{uid} {
      allow read, write: if isAdmin();
    }

    // ─── Deny all other access ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
