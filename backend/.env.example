# SaveLock Backend — Environment Variables
# Copy this file to .env and fill in the values

# ─── Server ─────────────────────────────────────────────────────
PORT=3001

# Frontend URL (for CORS) — change to your Netlify URL
FRONTEND_URL=https://savelock.netlify.app

# ─── Firebase Admin SDK ──────────────────────────────────────────
# Option 1: Paste your Firebase service account JSON as a single line
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"saving-ff0d3","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@saving-ff0d3.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40saving-ff0d3.iam.gserviceaccount.com"}

# Firebase project IDs (backup if service account not provided)
FIREBASE_PROJECT_ID=saving-ff0d3
FIREBASE_STORAGE_BUCKET=saving-ff0d3.firebasestorage.app

# ─── Admin ───────────────────────────────────────────────────────
# Secret key used to set admin claims
# Call: POST /api/auth/set-admin { targetUid, adminSecret }
ADMIN_SECRET=change_this_to_a_strong_random_secret_key

# ─── Optional: Razorpay (future payment verification) ────────────
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=xxxx
# RAZORPAY_WEBHOOK_SECRET=xxxx
